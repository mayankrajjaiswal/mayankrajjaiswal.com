---
// src/components/sections/Projects.astro
import { projects } from '../../data/projects';

// Assign appropriate decorative icons based on the category
const getCategoryIcon = (category: string) => {
  switch (category) {
    case 'Identity & Access Management':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`;
    case 'Cyber Awareness':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`;
    case 'Enterprise Security':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"></rect><rect x="2" y="14" width="20" height="8" rx="2" ry="2"></rect><line x1="6" y1="10" x2="6" y2="14"></line><line x1="18" y1="10" x2="18" y2="14"></line></svg>`;
    case 'Cloud Security':
      return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-purple-500"><path d="M17.5 19A3.5 3.5 0 0 0 21 15.5c0-2.79-2.54-4.5-5-4.5-.42-1.15-1.04-2.3-2.1-3C12.75 7.3 11.38 7 10 7a6.5 6.5 0 0 0-6.5 6.5C3.5 16.5 6.5 19 10 19h7.5z"></path></svg>`;
    default:
      return `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-500"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>`;
  }
};
---

<section id="projects" class="py-24 md:py-32 bg-white dark:bg-slate-900 border-t border-slate-200/80 dark:border-slate-800/80 relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="max-w-3xl mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-50 mb-4">
        Featured Initiatives
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        Selected projects spanning enterprise security, identity architecture, IoT research, and cybersecurity education.
      </p>
    </div>

    <!-- Redesigned Grid to look extremely attractive -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => {
        const tags = project.technologies || project.topics || [];
        const isPremium = project.status === 'Active';
        
        return (
          <div class={`group flex flex-col rounded-3xl p-8 border hover:-translate-y-1.5 transition-all duration-300 ${
            isPremium 
              ? 'border-blue-200 dark:border-blue-900/40 bg-gradient-to-b from-blue-50/20 to-transparent dark:from-blue-950/10 dark:to-transparent shadow-md' 
              : 'border-slate-200/80 dark:border-slate-800/80 bg-slate-50/40 dark:bg-slate-950/20'
          }`}>
            
            <div class="flex items-center justify-between mb-6">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800/80 flex items-center justify-center shadow-sm" set:html={getCategoryIcon(project.category)} />
                <span class="text-xs font-bold uppercase tracking-wider text-slate-500 dark:text-slate-400">
                  {project.category}
                </span>
              </div>
              {project.status && (
                <span class="px-2.5 py-1 text-[10px] font-extrabold uppercase tracking-widest bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 rounded-md border border-emerald-500/20">
                  {project.status}
                </span>
              )}
            </div>

            <h3 class="text-xl font-bold text-slate-900 dark:text-slate-50 mb-4 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug">
              {project.title}
            </h3>
            
            <p class="text-sm sm:text-base text-slate-600 dark:text-slate-400 leading-relaxed mb-8 flex-grow">
              {project.description}
            </p>

            {tags.length > 0 && (
              <div class="flex flex-wrap gap-1.5 pt-6 border-t border-slate-200/60 dark:border-slate-800/60">
                {tags.slice(0, 4).map(tech => (
                  <span class="px-2.5 py-1 text-xs font-semibold bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 rounded-lg border border-slate-200/80 dark:border-slate-800/80 shadow-sm">
                    {tech}
                  </span>
                ))}
                {tags.length > 4 && (
                  <span class="px-2.5 py-1 text-xs font-bold text-slate-500 dark:text-slate-500 bg-transparent">
                    +{tags.length - 4} more
                  </span>
                )}
              </div>
            )}

          </div>
        );
      })}
    </div>

  </div>
</section>
