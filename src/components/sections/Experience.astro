---
// src/components/sections/Experience.astro
import { experiences } from '../../data/experience';
---

<section id="experience" class="py-24 md:py-32 bg-slate-50 dark:bg-slate-950 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="max-w-3xl mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 mb-4">
        Professional Experience
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        Designing secure enterprise systems, leading engineering teams, and delivering trusted digital platforms for over fifteen years.
      </p>
    </div>

    <div class="relative border-l border-slate-200 dark:border-slate-800 ml-3 md:ml-6 space-y-20">
      {experiences.map((exp) => (
        <div class="relative pl-8 md:pl-16">
          <!-- Timeline Marker -->
          <div class="absolute -left-3.5 md:-left-4 top-1 w-7 h-7 rounded-full bg-slate-50 dark:bg-slate-950 border-4 border-blue-500 flex items-center justify-center"></div>
          
          <div class="flex flex-col gap-2 mb-6">
            <h3 class="text-2xl font-bold text-slate-900 dark:text-slate-50">{exp.company}</h3>
            <div class="flex flex-wrap items-center gap-4 text-sm font-medium">
              <span class="text-blue-600 dark:text-blue-400">{exp.role}</span>
              <span class="w-1.5 h-1.5 rounded-full bg-slate-300 dark:bg-slate-700"></span>
              <span class="text-slate-500 dark:text-slate-400">{exp.duration}</span>
            </div>
          </div>

          <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 md:p-8 border border-slate-200 dark:border-slate-800 shadow-sm hover:shadow-md transition-shadow duration-300">
            <p class="text-slate-700 dark:text-slate-300 leading-relaxed mb-8">
              {exp.overview}
            </p>
            
            <div class="grid md:grid-cols-2 gap-8">
              <div>
                <h4 class="text-sm font-semibold text-slate-900 dark:text-slate-50 uppercase tracking-wider mb-4 flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
                  Architecture & Impact
                </h4>
                <ul class="space-y-3">
                  {exp.impact.slice(0, 6).map(item => (
                    <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 text-slate-400 shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
                      <span>{item}</span>
                    </li>
                  ))}
                </ul>
              </div>

              <div>
                <h4 class="text-sm font-semibold text-slate-900 dark:text-slate-50 uppercase tracking-wider mb-4 flex items-center gap-2">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><polygon points="12 2 2 7 12 12 22 7 12 2"></polygon><polyline points="2 17 12 22 22 17"></polyline><polyline points="2 12 12 17 22 12"></polyline></svg>
                  Core Technologies & Focus
                </h4>
                <div class="flex flex-wrap gap-2">
                  {exp.contributions.map(tech => (
                    <span class="px-2.5 py-1 text-xs font-medium bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded border border-slate-200 dark:border-slate-700">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
            
            {exp.products && (
              <div class="mt-8 pt-6 border-t border-slate-100 dark:border-slate-800">
                <span class="text-sm font-medium text-slate-500 dark:text-slate-400 mr-3">Major Products:</span>
                <span class="text-sm text-slate-700 dark:text-slate-300 font-medium">
                  {exp.products.join(" • ")}
                </span>
              </div>
            )}
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
