---
// src/components/sections/Hero.astro
---

<section id="hero" class="relative max-w-7xl mx-auto px-6 py-24 md:py-32 flex flex-col md:flex-row items-center justify-between gap-12">
  <div class="flex-1 space-y-8">
    <div class="space-y-4">
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight text-slate-900 dark:text-slate-50 leading-tight">
        Building Trust <br />
        <span class="text-blue-600 dark:text-blue-500">Through Security.</span>
      </h1>
      
      <p class="text-xl md:text-2xl font-medium text-slate-700 dark:text-slate-300 max-w-2xl leading-relaxed">
        Enterprise Security Architect specializing in Identity & Access Management, Cybersecurity, Artificial Intelligence, Cloud Security, and Enterprise Software Architecture.
      </p>
      
      <p class="text-lg text-slate-600 dark:text-slate-400 max-w-2xl leading-relaxed">
        Over 15 years of experience designing and delivering enterprise-grade security solutions for global organizations. Helping organizations build secure, resilient, and trusted digital platforms.
      </p>
    </div>

    <div class="flex flex-wrap items-center gap-4 pt-4">
      <a href="#contact" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition-colors duration-200">
        Book a Meeting
      </a>
      <a href="#projects" class="inline-flex items-center justify-center px-6 py-3 rounded-lg border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-900 dark:text-slate-100 font-medium transition-colors duration-200">
        Explore My Work
      </a>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6 pt-12 border-t border-slate-200 dark:border-slate-800">
      <div>
        <p class="text-3xl font-bold text-slate-900 dark:text-slate-50">15+</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Years Experience</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-slate-900 dark:text-slate-50">5000+</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Students Mentored</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-slate-900 dark:text-slate-50">50+</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Technical Sessions</p>
      </div>
      <div>
        <p class="text-3xl font-bold text-slate-900 dark:text-slate-50">AWS</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">Certified</p>
      </div>
    </div>
  </div>

  <div class="flex-grow w-full max-w-md relative">
    <div class="aspect-[4/5] rounded-2xl overflow-hidden bg-slate-200 dark:bg-slate-800 border border-slate-200 dark:border-slate-800 relative group">
      <!-- Placeholder for Professional Portrait -->
      <div class="absolute inset-0 flex items-center justify-center text-slate-400 dark:text-slate-600">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <!-- Self-healing real portrait -->
      <img 
        src="/images/mayank-portrait.jpg" 
        alt="Mayank Raj Jaiswal" 
        class="absolute inset-0 object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-500" 
        onerror="this.style.opacity='0'; this.style.pointerEvents='none';" 
      />
    </div>
    
    <!-- Floating tags for a modern, engineering feel -->
    <div class="absolute -left-6 top-1/4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 px-4 py-2 rounded-lg shadow-sm">
      <span class="text-sm font-medium text-slate-900 dark:text-slate-100 flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-blue-500"></div>
        Identity
      </span>
    </div>
    <div class="absolute -right-6 bottom-1/3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 px-4 py-2 rounded-lg shadow-sm">
      <span class="text-sm font-medium text-slate-900 dark:text-slate-100 flex items-center gap-2">
        <div class="w-2 h-2 rounded-full bg-indigo-500"></div>
        AI Security
      </span>
    </div>
  </div>
</section>
