---
// src/components/layout/Header.astro
const links = [
  { label: 'About', href: '/#about' },
  { label: 'Experience', href: '/#experience' },
  { label: 'Projects', href: '/#projects' },
  { label: 'Research', href: '/#research' },
  { label: 'Blog', href: '/blog' },
  { label: 'Contact', href: '/#contact' },
];
---

<header class="fixed top-0 w-full z-50 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-slate-200/80 dark:border-slate-800/80 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="text-xl font-bold tracking-tight text-slate-900 dark:text-slate-50 hover:opacity-80 transition-opacity">
      Mayank Raj Jaiswal
    </a>
    
    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-6">
      {links.map(link => (
        <a 
          href={link.href}
          data-nav-link
          class="nav-link text-sm font-medium text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-50 transition-colors py-1.5 px-3 rounded-lg hover:bg-slate-100/50 dark:hover:bg-slate-900/50"
        >
          {link.label}
        </a>
      ))}
      
      <!-- Theme Toggle Button -->
      <button 
        id="theme-toggle" 
        class="p-2 text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-50 rounded-lg hover:bg-slate-100/50 dark:hover:bg-slate-900/50 transition-colors" 
        aria-label="Toggle Dark Mode"
      >
        <svg id="sun-icon" class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="M4.93 4.93l1.41 1.41"></path>
          <path d="M17.66 17.66l1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="M6.34 17.66l-1.41 1.41"></path>
          <path d="M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg id="moon-icon" class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <a href="/#contact" class="px-4 py-2 text-sm font-semibold text-white bg-blue-600 hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 rounded-lg shadow-sm hover:shadow transition-all">
        Connect
      </a>
    </nav>

    <!-- Mobile Navigation Controls -->
    <div class="flex items-center gap-2 md:hidden">
      <!-- Theme Toggle (Mobile) -->
      <button 
        id="theme-toggle-mobile" 
        class="p-2 text-slate-600 dark:text-slate-400 rounded-lg" 
        aria-label="Toggle Dark Mode"
      >
        <svg class="hidden dark:block" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2"></path>
          <path d="M12 20v2"></path>
          <path d="M4.93 4.93l1.41 1.41"></path>
          <path d="M17.66 17.66l1.41 1.41"></path>
          <path d="M2 12h2"></path>
          <path d="M20 12h2"></path>
          <path d="M6.34 17.66l-1.41 1.41"></path>
          <path d="M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg class="block dark:hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <!-- Mobile Menu Hamburger -->
      <button id="mobile-menu-btn" class="p-2 text-slate-600 dark:text-slate-400 rounded-lg" aria-label="Toggle Menu">
        <svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" x2="20" y1="12" y2="12"></line>
          <line x1="4" x2="20" y1="6" y2="6"></line>
          <line x1="4" x2="20" y1="18" y2="18"></line>
        </svg>
        <svg id="close-icon" class="hidden" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" x2="6" y1="6" y2="18"></line>
          <line x1="6" x2="18" y1="6" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Drawer Dropdown -->
  <div id="mobile-drawer" class="hidden border-b border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-slate-950/95 backdrop-blur-lg transition-all duration-300">
    <div class="px-6 py-6 flex flex-col gap-4">
      {links.map(link => (
        <a 
          href={link.href}
          data-drawer-link
          class="text-base font-medium text-slate-600 hover:text-slate-900 dark:text-slate-400 dark:hover:text-slate-50 transition-colors py-2"
        >
          {link.label}
        </a>
      ))}
      <a href="/#contact" data-drawer-link class="mt-2 w-full text-center px-4 py-3 text-base font-semibold text-white bg-blue-600 hover:bg-blue-700 rounded-lg shadow-sm">
        Connect
      </a>
    </div>
  </div>
</header>

<script is:inline>
  const setupHeaderLogic = () => {
    // 1. Mobile Menu Toggling
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const mobileDrawer = document.getElementById('mobile-drawer');
    const menuIcon = document.getElementById('menu-icon');
    const closeIcon = document.getElementById('close-icon');
    const drawerLinks = document.querySelectorAll('[data-drawer-link]');

    const toggleMenu = () => {
      const isExpanded = mobileDrawer.classList.toggle('hidden');
      menuIcon.classList.toggle('hidden', !isExpanded);
      closeIcon.classList.toggle('hidden', isExpanded);
    };

    if (mobileMenuBtn && mobileDrawer) {
      mobileMenuBtn.addEventListener('click', toggleMenu);
      
      // Close drawer when clicking any link
      drawerLinks.forEach(link => {
        link.addEventListener('click', () => {
          mobileDrawer.classList.add('hidden');
          menuIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');
        });
      });
    }

    // 2. Theme Toggle Sync
    const desktopToggle = document.getElementById('theme-toggle');
    const mobileToggle = document.getElementById('theme-toggle-mobile');

    const handleThemeToggle = () => {
      const isDark = document.documentElement.classList.toggle('dark');
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    };

    if (desktopToggle) desktopToggle.addEventListener('click', handleThemeToggle);
    if (mobileToggle) mobileToggle.addEventListener('click', handleThemeToggle);

    // 3. Scroll Active State Observer
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('[data-nav-link]');

    const observerOptions = {
      root: null,
      rootMargin: '-20% 0px -60% 0px', // When the section occupies the central focal area
      threshold: 0.1
    };

    const observerCallback = (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const id = entry.target.getAttribute('id');
          navLinks.forEach(link => {
            const href = link.getAttribute('href');
            // Safely extract the hash anchor (e.g. "/#about" -> "#about")
            const hash = href.includes('#') ? href.substring(href.indexOf('#')) : '';
            
            if (hash === `#${id}`) {
              link.classList.add('text-blue-600', 'dark:text-blue-500', 'bg-slate-100/80', 'dark:bg-slate-900/80', 'font-semibold');
              link.classList.remove('text-slate-600', 'dark:text-slate-400');
            } else {
              link.classList.remove('text-blue-600', 'dark:text-blue-500', 'bg-slate-100/80', 'dark:bg-slate-900/80', 'font-semibold');
              link.classList.add('text-slate-600', 'dark:text-slate-400');
            }
          });
        }
      });
    };

    const observer = new IntersectionObserver(observerCallback, observerOptions);
    sections.forEach(section => observer.observe(section));
    
    // Also handle direct clicks to highlight instantly without waiting for scroll debounce
    navLinks.forEach(link => {
      link.addEventListener('click', () => {
        navLinks.forEach(l => {
          l.classList.remove('text-blue-600', 'dark:text-blue-500', 'bg-slate-100/80', 'dark:bg-slate-900/80', 'font-semibold');
          l.classList.add('text-slate-600', 'dark:text-slate-400');
        });
        link.classList.add('text-blue-600', 'dark:text-blue-500', 'bg-slate-100/80', 'dark:bg-slate-900/80', 'font-semibold');
        link.classList.remove('text-slate-600', 'dark:text-slate-400');
      });
    });
  };

  // Run on page load
  setupHeaderLogic();

  // Support SPA swap events
  document.addEventListener('astro:after-swap', setupHeaderLogic);
</script>
