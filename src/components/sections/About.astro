---
// src/components/sections/About.astro

const philosophy = [
  "Security should never be an afterthought.",
  "Architecture should simplify complexity.",
  "Technology should empower people.",
  "Research should solve practical problems.",
  "Knowledge should always be shared.",
  "Continuous learning is a professional responsibility."
];

const currentFocus = [
  "Artificial Intelligence for Cybersecurity",
  "Identity & Access Management",
  "Zero Trust",
  "Cloud Security",
  "Enterprise Architecture",
  "Secure Software Engineering",
  "AboutIAM",
  "Research",
  "Technical Writing",
  "Speaking"
];
---

<section id="about" class="py-24 md:py-32 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 lg:grid-cols-12 gap-16">
    
    <div class="lg:col-span-5">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 mb-8">
        Who I Am
      </h2>
      <div class="space-y-6 text-lg text-slate-600 dark:text-slate-300 leading-relaxed">
        <p>
          Mayank Raj Jaiswal is an Enterprise Security Architect, AI Security Practitioner, Researcher, Author, Speaker, and Technology Leader with more than fifteen years of experience designing secure enterprise software.
        </p>
        <p>
          He specializes in Identity & Access Management, Cloud Security, PKI, HSM integration, OAuth, Zero Trust Architecture, Secure Software Engineering, DevSecOps, and Artificial Intelligence.
        </p>
        <p>
          Throughout his career, he has worked with global organizations such as Samsung and Thales, leading architecture and engineering initiatives that secure millions of digital identities and enterprise transactions.
        </p>
        <p>
          Beyond enterprise engineering, he actively contributes to cybersecurity awareness, technical education, research, mentoring, conference speaking, and open-source initiatives.
        </p>
        <p class="font-medium text-slate-900 dark:text-slate-50 pt-4 border-t border-slate-200 dark:border-slate-800">
          He believes that technology evolves rapidly, but trust remains the foundation of every successful digital platform.
        </p>
      </div>
    </div>

    <div class="lg:col-span-7 grid grid-cols-1 md:grid-cols-2 gap-12 lg:gap-16">
      
      <div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>
          Engineering Philosophy
        </h3>
        <ul class="space-y-4">
          {philosophy.map(item => (
            <li class="flex items-start gap-3 text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 text-slate-400 shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><circle cx="12" cy="12" r="10"></circle><path d="m12 16 4-4-4-4"></path><path d="M8 12h8"></path></svg>
          Current Focus
        </h3>
        <div class="flex flex-wrap gap-2">
          {currentFocus.map(item => (
            <span class="px-3 py-1.5 text-sm font-medium bg-slate-100 dark:bg-slate-800 text-slate-700 dark:text-slate-300 rounded-md border border-slate-200 dark:border-slate-700">
              {item}
            </span>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
