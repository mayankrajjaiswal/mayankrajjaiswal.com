---
// src/components/sections/Research.astro
import { researchTopics, futureResearch, publications } from '../../data/research';
---

<section id="research" class="py-24 md:py-32 bg-slate-50 dark:bg-slate-950 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="max-w-3xl mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 mb-4">
        Research & Publications
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        Deep technical expertise focused on advancing the state of enterprise security, digital identity, and artificial intelligence.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16">
      
      <div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          Areas of Deep Expertise
        </h3>
        <div class="flex flex-wrap gap-2">
          {researchTopics.map(topic => (
            <span class="px-3 py-1.5 text-sm font-medium bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-md border border-slate-200 dark:border-slate-700 shadow-sm">
              {topic}
            </span>
          ))}
        </div>
      </div>

      <div>
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          Future Research Vision
        </h3>
        <ul class="space-y-4">
          {futureResearch.map(item => (
            <li class="flex items-start gap-3 text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 text-slate-400 shrink-0"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              <span>{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <div>
      <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6">Selected Publications</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {publications.map(pub => (
          <div class="bg-white dark:bg-slate-900 rounded-xl p-6 border border-slate-200 dark:border-slate-800 flex flex-col hover:-translate-y-1 transition-transform duration-300">
            <span class="text-xs font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-3">
              {pub.type}
            </span>
            <h4 class="text-lg font-bold text-slate-900 dark:text-slate-50 mb-3">
              {pub.title}
            </h4>
            <p class="text-sm text-slate-600 dark:text-slate-400 leading-relaxed">
              {pub.description}
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
