---
// src/components/sections/Speaking.astro
import { speakingEngagements } from '../../data/speaking';
---

<section id="speaking" class="py-24 md:py-32 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="max-w-3xl mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 mb-4">
        Speaking & Community
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        Sharing knowledge, mentoring engineers, and contributing to the global cybersecurity community.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
      
      <div class="lg:col-span-5">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
          Technical Mentoring & Impact
        </h3>
        <div class="bg-slate-50 dark:bg-slate-950 rounded-2xl p-8 border border-slate-200 dark:border-slate-800">
          <p class="text-4xl font-bold text-slate-900 dark:text-slate-50 mb-2">5,000+</p>
          <p class="text-sm font-medium uppercase tracking-wider text-blue-600 dark:text-blue-400 mb-6">Students & Engineers Mentored</p>
          
          <ul class="space-y-4">
            <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 text-slate-400 shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Guided professionals in Cybersecurity, Identity, Cloud Security, and Secure Software Engineering.</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 text-slate-400 shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Conducted comprehensive workshops and technical sessions globally.</span>
            </li>
            <li class="flex items-start gap-3 text-sm text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-1 text-slate-400 shrink-0"><polyline points="20 6 9 17 4 12"></polyline></svg>
              <span>Active contributor to cybersecurity awareness and NGO education initiatives.</span>
            </li>
          </ul>
        </div>
      </div>

      <div class="lg:col-span-7">
        <h3 class="text-xl font-semibold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><path d="M2 10h3"></path><path d="M19 10h3"></path><path d="M12 2v3"></path><path d="M12 19v3"></path><path d="M5.636 5.636l2.122 2.122"></path><path d="M16.243 16.243l2.122 2.122"></path><path d="M5.636 18.364l2.122-2.122"></path><path d="M16.243 7.757l2.122-2.122"></path></svg>
          Selected Engagements
        </h3>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {speakingEngagements.map(engagement => (
            <div class="flex items-center gap-4 p-4 rounded-xl border border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950/50">
              <div class="w-10 h-10 rounded-full bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-600 dark:text-blue-400"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
              </div>
              <div>
                <p class="text-sm font-bold text-slate-900 dark:text-slate-50">{engagement.event}</p>
                <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5">{engagement.role}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>

  </div>
</section>
