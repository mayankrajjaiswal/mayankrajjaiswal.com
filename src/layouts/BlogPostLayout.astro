---
import Layout from './Layout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';

const { frontmatter } = Astro.props;
---

<Layout title={`${frontmatter.title} | Mayank Raj Jaiswal`} description={frontmatter.description}>
  <Header />
  <main class="flex-grow pt-32 pb-24 bg-white dark:bg-slate-950">
    <article class="max-w-3xl mx-auto px-6">
      
      <div class="mb-12 text-center md:text-left">
        <a href="/blog" class="inline-flex items-center gap-2 text-sm font-semibold text-blue-600 dark:text-blue-400 mb-6 hover:underline">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="19" x2="5" y1="12" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          Back to Blog
        </a>
        
        <div class="flex flex-wrap gap-2 justify-center md:justify-start mb-4">
          {frontmatter.tags.map((tag: string) => (
            <span class="px-2.5 py-1 text-xs font-semibold uppercase tracking-wider bg-slate-100 dark:bg-slate-800 text-slate-600 dark:text-slate-300 rounded">
              {tag}
            </span>
          ))}
        </div>

        <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-900 dark:text-slate-50 mb-4 leading-tight">
          {frontmatter.title}
        </h1>
        
        <div class="text-sm text-slate-500 dark:text-slate-400 font-medium">
          Published on {new Date(frontmatter.pubDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        </div>
      </div>

      <!-- Markdown Content rendering -->
      <div class="prose prose-slate dark:prose-invert max-w-none text-slate-700 dark:text-slate-300 leading-relaxed space-y-6">
        <slot />
      </div>

    </article>
  </main>
  <Footer />
</Layout>
