---
// src/components/layout/Footer.astro
const year = new Date().getFullYear();
---

<footer class="py-12 bg-white dark:bg-slate-950 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6 flex flex-col md:flex-row items-center justify-between gap-6">
    
    <div class="text-center md:text-left">
      <p class="text-sm font-semibold text-slate-900 dark:text-slate-50 mb-1">
        Building Trust Through Security.
      </p>
      <p class="text-xs text-slate-500 dark:text-slate-400">
        Enterprise Security &bull; Identity &bull; AI &bull; Research &bull; Leadership
      </p>
    </div>

    <div class="text-center md:text-right">
      <p class="text-xs text-slate-500 dark:text-slate-400 mb-1">
        &copy; {year} Mayank Raj Jaiswal. All rights reserved.
      </p>
      <p class="text-[10px] text-slate-400 dark:text-slate-500">
        Built with Astro + TailwindCSS.
      </p>
    </div>

  </div>
</footer>
