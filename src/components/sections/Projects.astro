---
// src/components/sections/Projects.astro
import { projects } from '../../data/projects';
---

<section id="projects" class="py-24 md:py-32 bg-white dark:bg-slate-900 border-t border-slate-200 dark:border-slate-800">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="max-w-3xl mb-16">
      <h2 class="text-3xl md:text-4xl font-semibold tracking-tight text-slate-900 dark:text-slate-50 mb-4">
        Featured Initiatives
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        Selected projects spanning enterprise security, identity architecture, IoT research, and cybersecurity education.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {projects.map((project) => {
        const tags = project.technologies || project.topics || [];
        return (
          <div class="group flex flex-col bg-slate-50 dark:bg-slate-950 rounded-2xl p-8 border border-slate-200 dark:border-slate-800 hover:border-blue-500 dark:hover:border-blue-500 transition-colors duration-300">
            
            <div class="flex items-center justify-between mb-6">
              <span class="text-xs font-semibold uppercase tracking-wider text-blue-600 dark:text-blue-400">
                {project.category}
              </span>
              {project.status && (
                <span class="px-2 py-1 text-[10px] font-bold uppercase tracking-wider bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 rounded">
                  {project.status}
                </span>
              )}
            </div>

            <h3 class="text-xl font-bold text-slate-900 dark:text-slate-50 mb-4 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">
              {project.title}
            </h3>
            
            <p class="text-slate-600 dark:text-slate-400 leading-relaxed mb-8 flex-grow">
              {project.description}
            </p>

            {tags.length > 0 && (
              <div class="flex flex-wrap gap-2 pt-6 border-t border-slate-200 dark:border-slate-800">
                {tags.slice(0, 5).map(tech => (
                  <span class="px-2 py-1 text-xs font-medium bg-white dark:bg-slate-900 text-slate-600 dark:text-slate-300 rounded border border-slate-200 dark:border-slate-700">
                    {tech}
                  </span>
                ))}
                {tags.length > 5 && (
                  <span class="px-2 py-1 text-xs font-medium bg-transparent text-slate-500 dark:text-slate-500">
                    +{tags.length - 5} more
                  </span>
                )}
              </div>
            )}

          </div>
        );
      })}
    </div>

  </div>
</section>
