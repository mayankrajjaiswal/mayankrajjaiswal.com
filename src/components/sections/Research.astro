---
// src/components/sections/Research.astro
import { researchTopics, futureResearch, publications } from '../../data/research';
---

<section id="research" class="py-24 md:py-32 bg-slate-50 dark:bg-slate-950 border-t border-slate-200/80 dark:border-slate-800/80 relative overflow-hidden">
  <!-- Soft Background Blobs -->
  <div class="absolute bottom-0 right-10 w-96 h-96 bg-blue-500/10 dark:bg-blue-500/5 rounded-full blur-3xl pointer-events-none -z-10"></div>

  <div class="max-w-7xl mx-auto px-6">
    
    <div class="max-w-3xl mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-slate-900 dark:text-slate-50 mb-4">
        Research & Publications
      </h2>
      <p class="text-lg text-slate-600 dark:text-slate-400 leading-relaxed">
        Deep technical expertise focused on advancing the state of enterprise security, digital identity, and artificial intelligence.
      </p>
    </div>

    <!-- Redesigned Grid layout -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 mb-16">
      
      <!-- Deep Expertise tags -->
      <div class="lg:col-span-7">
        <h3 class="text-lg font-bold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          Areas of Deep Expertise
        </h3>
        <div class="flex flex-wrap gap-2.5">
          {researchTopics.map(topic => (
            <span class="px-3 py-2 text-xs sm:text-sm font-semibold bg-white dark:bg-slate-900 text-slate-700 dark:text-slate-300 rounded-xl border border-slate-200/80 dark:border-slate-800/80 shadow-sm hover:border-blue-500/40 dark:hover:border-blue-500/30 transition-all cursor-default">
              {topic}
            </span>
          ))}
        </div>
      </div>

      <!-- Future Vision Checklist -->
      <div class="lg:col-span-5 bg-white dark:bg-slate-900 border border-slate-200/80 dark:border-slate-800/80 rounded-3xl p-8 shadow-sm">
        <h3 class="text-lg font-bold text-slate-900 dark:text-slate-50 mb-6 flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-indigo-500"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path><polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline><line x1="12" y1="22.08" x2="12" y2="12"></line></svg>
          Future Research Vision
        </h3>
        <ul class="space-y-4">
          {futureResearch.map(item => (
            <li class="flex items-start gap-3.5 text-sm text-slate-600 dark:text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 text-blue-500 shrink-0"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
              <span class="leading-relaxed">{item}</span>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Publications Shelf -->
    <div>
      <h3 class="text-lg font-bold text-slate-900 dark:text-slate-50 mb-6">Featured Publications</h3>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {publications.map(pub => (
          <div class="bg-white dark:bg-slate-900 rounded-2xl p-6 border border-slate-200/80 dark:border-slate-800/80 flex flex-col hover:-translate-y-1.5 hover:border-blue-500/50 dark:hover:border-blue-500/30 transition-all duration-300 shadow-sm hover:shadow-md">
            <div class="flex items-center justify-between mb-4">
              <span class="text-[10px] font-extrabold uppercase tracking-widest text-blue-600 dark:text-blue-400 bg-blue-50 dark:bg-blue-900/10 px-2 py-1 rounded-md border border-blue-100 dark:border-blue-900/20">
                {pub.type}
              </span>
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-slate-400"><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="M4.93 4.93l1.41 1.41"></path><path d="M17.66 17.66l1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="M6.34 17.66l-1.41 1.41"></path><path d="M19.07 4.93l-1.41 1.41"></path></svg>
            </div>
            <h4 class="text-base font-bold text-slate-900 dark:text-slate-50 mb-2 leading-snug">
              {pub.title}
            </h4>
            <p class="text-xs sm:text-sm text-slate-500 dark:text-slate-400 leading-relaxed flex-grow">
              {pub.description}
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
