---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="404: Not Found | Mayank Raj Jaiswal" 
  description="The page you are looking for does not exist."
>
  <main class="flex-grow flex items-center justify-center min-h-screen bg-slate-50 dark:bg-slate-950">
    <div class="text-center px-6">
      <h1 class="text-9xl font-bold text-slate-200 dark:text-slate-800 mb-4">404</h1>
      <h2 class="text-2xl md:text-3xl font-semibold text-slate-900 dark:text-slate-50 mb-6">Page Not Found</h2>
      <p class="text-slate-600 dark:text-slate-400 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a href="/" class="inline-flex items-center justify-center px-6 py-3 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700 transition-colors duration-200">
        Return Home
      </a>
    </div>
  </main>
</Layout>
