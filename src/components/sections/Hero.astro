---
// src/components/sections/Hero.astro
---

<section id="hero" class="relative max-w-7xl mx-auto px-6 pt-32 pb-24 md:pt-40 md:pb-32 flex flex-col lg:flex-row items-center justify-between gap-16 overflow-hidden">
  <!-- Glowing Background Mesh -->
  <div class="absolute top-1/4 left-1/4 -translate-x-1/2 -translate-y-1/2 w-[350px] h-[350px] bg-gradient-to-tr from-blue-500 to-indigo-600 rounded-full blur-[120px] opacity-20 dark:opacity-30 pointer-events-none -z-10"></div>
  <div class="absolute top-1/3 right-1/4 translate-x-1/2 w-[300px] h-[300px] bg-gradient-to-tr from-purple-500 to-pink-500 rounded-full blur-[100px] opacity-10 dark:opacity-25 pointer-events-none -z-10"></div>

  <!-- Text Column -->
  <div class="flex-1 space-y-8 text-center lg:text-left z-10">
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-blue-50/80 dark:bg-blue-900/30 border border-blue-100 dark:border-blue-800 text-xs font-semibold text-blue-700 dark:text-blue-400">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-600 dark:bg-blue-400 animate-pulse"></span>
      Enterprise Security Architect
    </div>

    <div class="space-y-4">
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight text-slate-900 dark:text-slate-50 leading-[1.1] mb-6">
        Building Trust <br />
        <span class="bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400 bg-clip-text text-transparent">Through Security.</span>
      </h1>
      
      <p class="text-lg sm:text-xl md:text-2xl font-medium text-slate-700 dark:text-slate-300 max-w-2xl mx-auto lg:mx-0 leading-relaxed">
        Enterprise Security Architect specializing in Identity & Access Management, Cybersecurity, Artificial Intelligence, Cloud Security, and Enterprise Software Architecture.
      </p>
    </div>

    <div class="flex flex-wrap justify-center lg:justify-start items-center gap-4 pt-4">
      <a href="#contact" class="inline-flex items-center justify-center px-6 py-3.5 rounded-xl bg-blue-600 text-white font-semibold shadow-md hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500 transition-all hover:-translate-y-0.5">
        Book a Meeting
      </a>
      <a href="#projects" class="inline-flex items-center justify-center px-6 py-3.5 rounded-xl border border-slate-300 dark:border-slate-700 hover:bg-slate-100 dark:hover:bg-slate-800/80 text-slate-900 dark:text-slate-100 font-semibold transition-all hover:-translate-y-0.5">
        Explore My Work
      </a>
    </div>

    <!-- Metrics Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 pt-12 border-t border-slate-200/80 dark:border-slate-800/80 max-w-2xl mx-auto lg:mx-0">
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-50 bg-gradient-to-r from-slate-950 to-slate-700 dark:from-white dark:to-slate-400 bg-clip-text text-transparent">15+</p>
        <p class="text-xs sm:text-sm font-medium text-slate-500 dark:text-slate-400 mt-1">Years Experience</p>
      </div>
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-50 bg-gradient-to-r from-slate-950 to-slate-700 dark:from-white dark:to-slate-400 bg-clip-text text-transparent">5000+</p>
        <p class="text-xs sm:text-sm font-medium text-slate-500 dark:text-slate-400 mt-1">Students Mentored</p>
      </div>
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-50 bg-gradient-to-r from-slate-950 to-slate-700 dark:from-white dark:to-slate-400 bg-clip-text text-transparent">50+</p>
        <p class="text-xs sm:text-sm font-medium text-slate-500 dark:text-slate-400 mt-1">Sessions Conducted</p>
      </div>
      <div>
        <p class="text-3xl sm:text-4xl font-extrabold text-slate-900 dark:text-slate-50 bg-gradient-to-r from-slate-950 to-slate-700 dark:from-white dark:to-slate-400 bg-clip-text text-transparent">PhD</p>
        <p class="text-xs sm:text-sm font-medium text-slate-500 dark:text-slate-400 mt-1">In Progress</p>
      </div>
    </div>
  </div>

  <!-- Portrait Column -->
  <div class="flex-grow w-full max-w-[340px] md:max-w-md relative z-10 flex justify-center">
    <div class="relative w-full aspect-[4/5] rounded-3xl overflow-hidden bg-slate-200 dark:bg-slate-900/60 border border-slate-200/80 dark:border-slate-800/80 shadow-2xl hover:shadow-3xl transition-shadow duration-500">
      <!-- Portrait Placeholder -->
      <div class="absolute inset-0 flex items-center justify-center text-slate-400 dark:text-slate-600 bg-gradient-to-tr from-slate-100 to-slate-200 dark:from-slate-900 dark:to-slate-950">
        <svg xmlns="http://www.w3.org/2000/svg" width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="opacity-60">
          <path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <img 
        src="/images/mayank-portrait.jpg" 
        alt="Mayank Raj Jaiswal" 
        class="absolute inset-0 object-cover w-full h-full grayscale hover:grayscale-0 transition-all duration-500" 
        onerror="this.style.opacity='0'; this.style.pointerEvents='none';" 
      />
    </div>
    
    <!-- Float Tags -->
    <div class="absolute -left-6 top-1/4 bg-white/90 dark:bg-slate-900/90 border border-slate-200/80 dark:border-slate-800/80 px-4 py-2 rounded-xl shadow-lg backdrop-blur-md">
      <span class="text-xs sm:text-sm font-bold text-slate-950 dark:text-slate-50 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-blue-500"></span>
        Zero Trust
      </span>
    </div>
    <div class="absolute -right-6 bottom-1/4 bg-white/90 dark:bg-slate-900/90 border border-slate-200/80 dark:border-slate-800/80 px-4 py-2 rounded-xl shadow-lg backdrop-blur-md">
      <span class="text-xs sm:text-sm font-bold text-slate-950 dark:text-slate-50 flex items-center gap-2">
        <span class="w-2.5 h-2.5 rounded-full bg-indigo-500"></span>
        Cryptographic HSM
      </span>
    </div>
  </div>
</section>
